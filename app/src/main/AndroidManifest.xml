<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:name=".BmiApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:label="@string/app_name"
        android:icon="@mipmap/bmi_logo"
        android:roundIcon="@mipmap/bmi_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.BMICalculatorWeightLossTracker">
        <activity
            android:name=".ui.activity.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.BMICalculatorWeightLossTracker">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.activity.DataInputActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.BmiResultActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.MainActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.MeActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.FeedbackActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>
        <activity
            android:name=".ui.activity.LanguageActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.HistoryActivity"
            android:exported="false"
            android:theme="@style/Theme.BMICalculatorWeightLossTracker" />

    </application>

</manifest>