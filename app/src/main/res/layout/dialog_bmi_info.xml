<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/bg_bottom_sheet_white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/tip_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_bmi_tip"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/bmi_teenager_tip"
            android:textSize="20sp"
            android:textColor="#000000"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/montserrat_extrabold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>
        <TextView
            android:id="@+id/tv_bmi_tip_value"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="12 years old (Girl)"
            android:layout_marginTop="2.5dp"
            app:layout_constraintStart_toStartOf="@+id/tv_bmi_tip"
            app:layout_constraintTop_toBottomOf="@id/tv_bmi_tip"
            />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <bmicalculator.bmi.calculator.weightlosstracker.ui.widget.BmiGaugeView
        android:id="@+id/bmiGauge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="9.53dp"
        app:layout_constraintTop_toBottomOf="@id/tip_layout"
        app:layout_constraintStart_toStartOf="parent" />
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:paddingStart="15dp"
        android:paddingEnd="30dp"
        android:visibility="visible"
        tools:listitem="@layout/item_bmi_range"
        app:layout_constraintTop_toBottomOf="@+id/bmiGauge"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
    <TextView
        android:id="@+id/btn_got_it"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_save_rounded"
        android:gravity="center"
        android:text="@string/got_it"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:fontFamily="@font/montserrat_extrabold"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:paddingTop="15.5dp"
        android:paddingBottom="15.5dp"
        app:layout_constraintTop_toBottomOf="@id/rvStatus"
        app:layout_constraintBottom_toBottomOf="parent"/>


</androidx.constraintlayout.widget.ConstraintLayout>