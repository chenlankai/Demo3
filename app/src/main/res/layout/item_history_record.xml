<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="13.5dp"
    android:paddingBottom="13.5dp"
    android:layout_marginStart="15dp"
    android:layout_marginEnd="15dp"
    android:layout_marginBottom="15dp"
    android:background="@drawable/bg_rounded_white_radius15"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:id="@+id/tvBMI"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="24.7"
        android:textSize="27sp"
        android:fontFamily="@font/montserrat_extrabold"
        android:textColor="#000000"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/ivOval"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/oval"
        android:layout_marginTop="3dp"
        app:layout_constraintStart_toStartOf="@id/tvBMI"
        app:layout_constraintTop_toBottomOf="@id/tvBMI" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:text="Normal"
        android:textSize="16sp"
        android:fontFamily="@font/montserrat_regular"
        app:layout_constraintTop_toTopOf="@id/ivOval"
        app:layout_constraintBottom_toBottomOf="@id/ivOval"
        app:layout_constraintStart_toEndOf="@id/ivOval" />

    <TextView
        android:id="@+id/tvDateTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8.5dp"
        android:text="May 6, 2021 \nMorning"
        android:maxLines="2"
        android:textSize="14sp"
        android:fontFamily="@font/montserrat_regular"
        android:textColor="#000000"
        android:gravity="end"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/ivChevronRight"
        app:layout_constraintBottom_toBottomOf="parent"/>
    <ImageView
        android:id="@+id/ivChevronRight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/chevron_right"
        android:layout_marginEnd="15dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>