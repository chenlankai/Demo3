<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_description_rounded">
    <TextView
        android:id="@+id/tvAppTag"
        android:layout_width="29.5dp"
        android:layout_height="14.5dp"
        android:background="@drawable/bg_app_tag"
        android:textSize="8sp"
        android:includeFontPadding="false"
        android:text="AD"
        android:gravity="center"
        android:fontFamily="@font/montserrat_extrabold"
        android:textColor="#FFFFFF"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivAppIcon"
        android:layout_width="49dp"
        android:layout_height="49dp"
        android:scaleType="centerCrop"
        android:layout_marginTop="15dp"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="15dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:src="@drawable/icon_recommend_s5" />

    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginTop="-0.5dp"
        android:layout_marginEnd="20dp"
        android:textColor="#000000"
        android:textSize="14sp"
        android:fontFamily="@font/montserrat_regular"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/ivAppIcon"
        app:layout_constraintTop_toTopOf="@+id/ivAppIcon"
        tools:text="Home Workout - No Equipments" />

    <TextView
        android:id="@+id/tvAppDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="#000000"
        android:alpha="0.8"
        android:textSize="12sp"
        android:layout_marginTop="2dp"
        app:layout_constraintEnd_toEndOf="@id/tvAppName"
        app:layout_constraintStart_toStartOf="@+id/tvAppName"
        app:layout_constraintTop_toBottomOf="@+id/tvAppName"
        tools:text="Weight Loss, Lose Belly Fat" />
    <ImageView
        android:id="@+id/ivStar"
        android:layout_width="66dp"
        android:layout_height="12dp"
        android:layout_marginTop="3dp"
        android:src="@drawable/icon_recommend_grade"
        app:layout_constraintTop_toBottomOf="@id/tvAppDesc"
        app:layout_constraintStart_toStartOf="@id/tvAppName"/>


    <TextView
        android:id="@+id/tvRating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:textColor="#757575"
        android:textSize="12sp"
        tools:text="4.8"
        app:layout_constraintTop_toTopOf="@id/ivStar"
        app:layout_constraintBottom_toBottomOf="@id/ivStar"
        app:layout_constraintStart_toEndOf="@id/ivStar"/>


</androidx.constraintlayout.widget.ConstraintLayout>