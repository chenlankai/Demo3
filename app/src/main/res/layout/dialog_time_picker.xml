<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_bottom"
    android:padding="0dp">

    <TextView
        android:id="@+id/tvTimeTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/montserrat_extrabold"
        android:text="TIME"
        android:textColor="#000000"
        android:textSize="18sp"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/pickerContainer"
        android:layout_width="match_parent"
        android:layout_height="238.5dp"
        android:layout_marginTop="25.5dp"
        app:layout_constraintTop_toBottomOf="@id/tvTimeTitle">

        <bmicalculator.bmi.calculator.weightlosstracker.ui.widget.WheelView
            android:id="@+id/timePicker"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <View
            android:id="@+id/timeCenterHelper"
            android:layout_width="match_parent"
            android:layout_height="31dp"
            android:visibility="invisible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="100dp"
            android:layout_height="0.5dp"
            android:background="#3659CF"
            app:layout_constraintBottom_toTopOf="@id/timeCenterHelper"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <View
            android:layout_width="100dp"
            android:layout_height="0.5dp"
            android:background="#3659CF"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/timeCenterHelper" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="7.5dp"
        android:orientation="horizontal"
        android:layout_marginBottom="15dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/pickerContainer">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginEnd="15dp"
            android:layout_weight="1"
            android:fontFamily="@font/montserrat_extrabold"
            android:text="CANCEL"
            android:textColor="#000000"
            android:textSize="18sp"
            app:backgroundTint="#F2F2F2"
            app:cornerRadius="27.5dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDone"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:fontFamily="@font/montserrat_extrabold"
            android:text="DONE"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            app:backgroundTint="#3659CF"
            app:cornerRadius="27.5dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>