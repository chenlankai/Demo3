<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EAEAEE"
    android:orientation="vertical">
    <bmicalculator.bmi.calculator.weightlosstracker.util.ImmersiveView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#EAEAEE" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvTitleCalculator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="18dp"
            android:fontFamily="@font/montserrat_extrabold"
            android:gravity="center"
            android:textColor="#000000"
            android:text="@string/calculator"
            android:textSize="24sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/ivTitleIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="17dp"
            android:gravity="center"
            android:src="@drawable/icon_general_me"
            android:contentDescription="@string/mine"
            app:layout_constraintBottom_toBottomOf="@+id/tvTitleCalculator"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tvTitleCalculator" />

    </androidx.constraintlayout.widget.ConstraintLayout>
<!--    androidx.core.widget.NestedScrollView -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/innerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/conLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvTitleWeight"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat_regular"
                    android:gravity="center"
                    android:textSize="14sp"

                    android:text="@string/weight"
                    app:layout_constraintEnd_toStartOf="@+id/tvTitleHeight"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
<!--                android:layout_marginTop="19dp"-->

                <TextView
                    android:id="@+id/tvTitleHeight"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat_regular"
                    android:gravity="center"
                    android:text="@string/height"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toEndOf="@+id/tvTitleWeight"
                    app:layout_constraintTop_toTopOf="@id/tvTitleWeight" />

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guideline_mid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.5" />

                <EditText
                    android:id="@+id/etWeight"
                    android:layout_width="0dp"
                    android:layout_height="68dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="7.5dp"
                    android:layout_marginTop="15dp"
                    android:textColor="#000000"
                    android:background="@drawable/bg_rounded_white"
                    android:gravity="center"
                    android:hint="@string/default_weight_hint"
                    android:textSize="30sp"
                    android:inputType="numberDecimal"
                    android:maxLength="6"
                    android:fontFamily="@font/montserrat_extrabold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/guideline_mid"
                    app:layout_constraintTop_toBottomOf="@+id/tvTitleWeight" />
                <EditText
                    android:id="@+id/etWeightKg"
                    android:layout_width="0dp"
                    android:layout_height="68dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="7.5dp"
                    android:layout_marginTop="15dp"
                    android:textColor="#000000"
                    android:background="@drawable/bg_rounded_white"
                    android:gravity="center"
                    android:hint="@string/default_weight_hint"
                    android:textSize="30sp"
                    android:inputType="numberDecimal"
                    android:maxLength="6"
                    android:fontFamily="@font/montserrat_extrabold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/guideline_mid"
                    app:layout_constraintTop_toBottomOf="@+id/tvTitleWeight" />

                <EditText
                    android:id="@+id/etHeightCm"
                    android:layout_width="0dp"
                    android:layout_height="68dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginStart="7.5dp"
                    android:visibility="gone"
                    android:background="@drawable/bg_rounded_white"
                    android:gravity="center"
                    android:hint="@string/default_height_cm_hint"
                    android:textSize="30sp"
                    android:inputType="numberDecimal"
                    android:maxLength="5"
                    android:fontFamily="@font/montserrat_extrabold"
                    app:layout_constraintTop_toBottomOf="@+id/tvTitleWeight"
                    app:layout_constraintStart_toEndOf="@id/guideline_mid"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginEnd="20dp" />
                <EditText
                    android:id="@+id/etHeightFt"
                    android:layout_width="0dp"
                    android:layout_height="68dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginStart="7.5dp"
                    android:textColor="#000000"
                    android:background="@drawable/bg_rounded_white"
                    android:gravity="center"
                    android:hint="@string/default_height_ft_hint"
                    android:textSize="30sp"
                    android:inputType="number"
                    android:maxLength="2"
                    android:fontFamily="@font/montserrat_extrabold"
                    app:layout_constraintHorizontal_weight="0.875"
                    app:layout_constraintStart_toEndOf="@+id/guideline_mid"
                    app:layout_constraintEnd_toStartOf="@+id/space1"
                    app:layout_constraintTop_toBottomOf="@+id/tvTitleWeight" />

                <Space
                    android:id="@+id/space1"
                    android:layout_width="0dp"
                    android:layout_height="68dp"
                    android:layout_marginTop="15dp"
                    app:layout_constraintEnd_toStartOf="@+id/etHeightIn"
                    app:layout_constraintStart_toEndOf="@id/etHeightFt"
                    app:layout_constraintHorizontal_weight="0.0687"
                    app:layout_constraintTop_toBottomOf="@+id/tvTitleWeight"/>

                <EditText
                    android:id="@+id/etHeightIn"
                    android:layout_width="0dp"
                    android:layout_height="68dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginEnd="20dp"
                    android:textColor="#000000"
                    android:background="@drawable/bg_rounded_white"
                    android:fontFamily="@font/montserrat_extrabold"
                    android:gravity="center"
                    android:hint="@string/default_height_in_hint"
                    android:maxLength="3"
                    android:inputType="number"
                    android:textSize="30sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_weight="1.05625"
                    app:layout_constraintStart_toEndOf="@+id/space1"
                    app:layout_constraintTop_toBottomOf="@+id/tvTitleWeight" />

                <androidx.constraintlayout.widget.Group
                    android:id="@+id/groupFtIn"
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:constraint_referenced_ids="etHeightFt,space1,etHeightIn" />

                <androidx.constraintlayout.widget.Group
                    android:id="@+id/groupCm"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:constraint_referenced_ids="etHeightCm" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="10dp">

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggleWeight"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="20dp"
                    android:background="@drawable/bg_toggle_container"
                    app:checkedButton="@id/btnLb"
                    app:cornerRadius="18dp"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/toggleHeight"
                    app:layout_constraintTop_toTopOf="parent"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLb"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:backgroundTint="@android:color/transparent"
                        android:fontFamily="@font/montserrat_extrabold"
                        android:text="lb"
                        android:textColor="?attr/colorOnSurface"


                        android:padding="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnKg"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:backgroundTint="@android:color/transparent"
                        android:fontFamily="@font/montserrat_extrabold"
                        android:text="kg"
                        android:textColor="?attr/colorOnSurface"
                        android:padding="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp" />
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggleHeight"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="15dp"
                    android:layout_marginEnd="20dp"
                    android:background="@drawable/bg_toggle_container"
                    app:checkedButton="@id/btnFTin"
                    app:cornerRadius="30dp"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toEndOf="@id/toggleWeight"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFTin"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:backgroundTint="@android:color/transparent"
                        android:fontFamily="@font/montserrat_extrabold"
                        android:text="ft·in"
                        android:textColor="?attr/colorOnSurface"
                        android:padding="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCM"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:backgroundTint="@android:color/transparent"
                        android:fontFamily="@font/montserrat_extrabold"
                        android:text="cm"
                        android:textColor="?attr/colorOnSurface"
                        android:padding="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp" />
                </com.google.android.material.button.MaterialButtonToggleGroup>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp">

                <TextView
                    android:id="@+id/tvTitleTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/log_weight_time"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:fontFamily="@font/montserrat_regular"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tvData"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginStart="20dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:textColor="#000000"
                    android:background="@drawable/bg_rounded_white"
                    android:hint="@string/default_date_hint"
                    android:gravity="center"
                    android:textSize="20sp"
                    android:includeFontPadding="false"
                    android:fontFamily="@font/montserrat_extrabold"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/tvAfternoon"
                    app:layout_constraintTop_toBottomOf="@+id/tvTitleTime" />

                <TextView
                    android:id="@+id/tvAfternoon"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginEnd="20dp"
                    android:layout_marginStart="15dp"
                    android:background="@drawable/bg_rounded_white"
                    android:text="@string/morning"
                    android:gravity="center"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:fontFamily="@font/montserrat_extrabold"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toEndOf="@+id/tvData"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvTitleTime" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp">

                <TextView
                    android:id="@+id/tvTitleAge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/age"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:fontFamily="@font/montserrat_regular"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_marginTop="15dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="25dp"
                    android:layout_marginEnd="25dp"
                    android:background="@drawable/bg_rounded_white"
                    app:layout_constraintTop_toBottomOf="@+id/tvTitleAge">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvAge"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_age"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:layout_width="15dp"
                        android:layout_height="11dp"
                        android:src="@drawable/icon_age_arrows"
                        android:layout_marginTop="6dp"
                        android:importantForAccessibility="no"
                        app:layout_constraintTop_toBottomOf="@id/rvAge"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="20dp"> <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutMale"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_marginStart="25dp"
                android:background="@drawable/bg_rounded_white"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/layoutFemale"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/ivGenderM"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:src="@drawable/icon_gender_m"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="36dp"
                    android:contentDescription="@string/male"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/male"
                    android:fontFamily="@font/montserrat_regular"
                    android:textSize="14sp"
                    android:layout_marginTop="0.5dp"
                    app:layout_constraintTop_toBottomOf="@+id/ivGenderM"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <ImageView
                    android:id="@+id/ivCheckMale"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/icon_gender_check"
                    android:layout_marginTop="6dp"
                    android:layout_marginEnd="7dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layoutFemale"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_marginStart="15dp"
                    android:layout_marginEnd="25dp"
                    android:background="@drawable/bg_rounded_white"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/layoutMale"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:id="@+id/ivGenderF"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:src="@drawable/icon_gender_f"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="36dp"
                        android:contentDescription="@string/female"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/female"
                        android:textSize="14sp"
                        android:fontFamily="@font/montserrat_regular"
                        android:layout_marginTop="0.5dp"
                        app:layout_constraintTop_toBottomOf="@+id/ivGenderF"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <ImageView
                        android:id="@+id/ivCheckFemale"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/icon_gender_check"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="7dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>
    </ScrollView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCalculate"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="20dp"
            android:text="@string/CALCULATE"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            app:cornerRadius="30dp"
            app:backgroundTint="#3659CF"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:letterSpacing="0.05"
            android:fontFamily="@font/montserrat_extrabold"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>