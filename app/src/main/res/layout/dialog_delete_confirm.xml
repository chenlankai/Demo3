<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="301dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_rounded_dialog"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/delete_conf"

        android:textColor="#000"
        android:gravity="center"
        android:fontFamily="@font/montserrat_extrabold"


        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="15dp"
        android:layout_marginTop="25dp"
        android:layout_marginEnd="15dp"
        />

    <TextView
        android:id="@+id/are_you_sur"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/are_you_sur"


        android:textColor="#000000"
        android:gravity="center"
        android:textSize="13sp"
        android:fontFamily="@font/montserrat_regular"

        app:layout_constraintEnd_toEndOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="@id/tvTitle"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"

        android:layout_marginStart="23dp"
        android:layout_marginTop="9.5dp"
        android:layout_marginEnd="23dp"/>

    <View
        android:id="@+id/path"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#979797"
        android:layout_marginTop="25dp"
        android:alpha="0.3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/are_you_sur" />

    <View
        android:id="@+id/path_2"
        android:layout_width="0.5dp"
        android:layout_height="55dp"

        android:layout_marginTop="0dp"
        android:layout_marginBottom="0dp"

        android:alpha="0.3"
        android:background="#979797"


        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/path" />

    <TextView
        android:id="@+id/cancel_button"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:layout_centerHorizontal="true"
        android:layout_centerVertical="true"

        android:gravity="center"
        android:text="@string/cancel"
        android:textAppearance="@style/cancel"
        android:background="?attr/selectableItemBackground"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/path"
        app:layout_constraintEnd_toEndOf="@id/path_2"/>

    <TextView
        android:id="@+id/delete_button"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:layout_centerHorizontal="true"
        android:layout_centerVertical="true"


        android:gravity="center"
        android:text="@string/delete"
        android:textAppearance="@style/delete"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        app:layout_constraintStart_toStartOf="@id/path_2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/path"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>