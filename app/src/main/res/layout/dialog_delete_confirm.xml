<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_rounded_dialog"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/delete_conf"

        android:textColor="#000"
        android:fontFamily="@font/montserrat_extrabold"


        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="15dp"
        android:layout_marginTop="25dp"
        android:layout_marginEnd="15dp"
        />

    <TextView
        android:id="@+id/are_you_sur"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/are_you_sur"


        android:textColor="#000000"
        android:textSize="13sp"
        android:fontFamily="@font/montserrat_regular"

        app:layout_constraintEnd_toEndOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="@id/tvTitle"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"

        android:layout_marginTop="9.5dp"
        android:layout_marginEnd="5dp"/>



    <TextView
        android:id="@+id/cancel_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:text="@string/cancel"
        android:textAppearance="@style/cancel"
        android:layout_marginEnd="14.5dp"

        android:fontFamily="@font/montserrat_extrabold"
        android:textSize="16sp"

        app:layout_constraintBottom_toBottomOf="@id/delete_button"
        app:layout_constraintTop_toTopOf="@+id/delete_button"
        app:layout_constraintEnd_toStartOf="@id/delete_button"/>

    <TextView
        android:id="@+id/delete_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_centerVertical="true"


        android:gravity="center"
        android:text="@string/delete"
        android:textAppearance="@style/delete"
        android:clickable="true"
        android:layout_marginBottom="19.5dp"
        android:layout_marginEnd="4.5dp"
        android:layout_marginTop="28dp"
        android:textSize="16sp"
        android:fontFamily="@font/montserrat_extrabold"
        app:layout_constraintEnd_toEndOf="@id/are_you_sur"
        app:layout_constraintTop_toBottomOf="@+id/are_you_sur"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>